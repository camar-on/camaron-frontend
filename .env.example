# Backend API — all auth, data, and realtime goes through the backend.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# MediaMTX — the browser plays streams directly from here (HLS + WebRTC).
# Production should swap these for public HTTPS URLs (e.g. https://stream.camar-on.com).
NEXT_PUBLIC_MEDIAMTX_BASE_URL=http://localhost:8888
NEXT_PUBLIC_MEDIAMTX_WEBRTC_BASE_URL=http://localhost:8889
